# IDE / editor (local settings only)
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor - keep shared project rules, ignore local IDE state
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# MCP tooling (local only, generated by the IDE)
mcps/

# Release build output
dist/
*.zip

# Environment and secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary and backup files
*.tmp
*.temp
*.bak
*.orig

# Local test / scratch files
scratch/
temp/
tmp/